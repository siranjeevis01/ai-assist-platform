# ============================================
# AI Agent - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Database
MYSQL_ROOT_PASSWORD=your-strong-password-here
MYSQL_DATABASE=AiAgentDb
DB_CONNECTION=Server=mysql;Port=3306;Database=AiAgentDb;User=root;Password=your-strong-password-here

# JWT Secret (change this!)
JWT_SECRET_KEY=your-super-secure-jwt-key-at-least-32-chars

# Google OAuth (for Calendar & Gmail integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# SMTP Email
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Trello
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_SECRET=your-trello-api-secret
TRELLO_ACCESS_TOKEN=your-trello-access-token

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# App URLs (for production, set to your deployed domain)
AI_AGENT_BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost

# Ports (change if needed)
BACKEND_PORT=5000
FRONTEND_PORT=80
MYSQL_PORT=3306
