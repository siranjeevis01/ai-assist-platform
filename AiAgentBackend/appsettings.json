{
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=AiAgentDb;User=root;",
    "ProductionConnection": "Server=prod-db.example.com;Port=3306;Database=AiAgentDb;User=aiagent_user;Password=${PROD_DB_PASSWORD};"
  },
  "Password": {
    "DevelopmentMode": true,
    "MinimumLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": true
  },
  "Jwt": {
    "Key": "super-secure-32-char-key-1234567890123456",
    "Issuer": "AiAgentBackend",
    "Audience": "AiAgentUsers",
    "AccessTokenMinutes": 1440
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}",
    "EnableSsl": true
  },
  "Messaging": {
    "Telegram": {
      "BotToken": "${TELEGRAM_BOT_TOKEN}",
      "WebhookUrl": "https://yourdomain.com/api/telegram/webhook",
      "Enabled": true
    },
    "WhatsApp": {
      "Enabled": true,
      "Provider": "Webhook",
      "WebhookUrl": "https://yourdomain.com/api/whatsapp/webhook",
      "VerifyToken": "${WHATSAPP_VERIFY_TOKEN}",
      "AccessToken": "${WHATSAPP_ACCESS_TOKEN}",
      "PhoneNumberId": "${WHATSAPP_PHONE_NUMBER_ID}",
      "BusinessAccountId": "${WHATSAPP_BUSINESS_ACCOUNT_ID}"
    }
  },
  "Google": {
    "ClientId": "${GOOGLE_CLIENT_ID}",
    "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
    "RedirectUri": "http://localhost:5000/api/google/callback"
  },
  "Trello": {
    "ApiKey": "${TRELLO_API_KEY}",
    "ApiSecret": "${TRELLO_API_SECRET}",
    "AccessToken": "${TRELLO_ACCESS_TOKEN}",
    "DefaultBoardId": "${TRELLO_DEFAULT_BOARD_ID}",
    "ToDoListId": "${TRELLO_TODO_LIST_ID}",
    "InProgressListId": "${TRELLO_INPROGRESS_LIST_ID}",
    "DoneListId": "${TRELLO_DONE_LIST_ID}"
  },
  "Hangfire": {
    "WorkerCount": 4,
    "QueuePollInterval": "00:00:30",
    "DashboardEnabled": true
  },
  "AiAgent": {
    "BaseUrl": "${AI_AGENT_BASE_URL}",
    "WelcomeMessage": "👋 Welcome to AI Agent! I can help you manage your calendar, tasks, and emails.",
    "FallbackResponse": "I'm not sure how to help with that. I can assist with scheduling, tasks, emails, and reminders.",
    "MaxMessageLength": 1000,
    "PreferredMessaging": "telegram",
    "EnableGoogleIntegration": true,
    "EnableTrelloIntegration": true
  },
  "Gemini": {
    "ApiKey": "${GEMINI_API_KEY}"
  },
  "OpenAI": {
    "ApiKey": "${OPENAI_API_KEY}",
    "Model": "gpt-4o-mini"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  }
}
