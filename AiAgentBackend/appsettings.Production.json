{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST:-localhost};Port=${DB_PORT:-3306};Database=${DB_NAME:-AiAgentDb};User=${DB_USER:-root};Password=${DB_PASSWORD:-};SslMode=VerifyFull;"
  },
  "Password": {
    "DevelopmentMode": false
  },
  "Google": {
    "RedirectUri": "${AI_AGENT_BASE_URL}/api/google/callback"
  },
  "Messaging": {
    "Telegram": {
      "WebhookUrl": "${AI_AGENT_BASE_URL}/api/telegram/webhook"
    },
    "WhatsApp": {
      "WebhookUrl": "${AI_AGENT_BASE_URL}/api/whatsapp/webhook"
    }
  },
  "AiAgent": {
    "BaseUrl": "${AI_AGENT_BASE_URL}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}