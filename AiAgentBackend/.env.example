# Environment variables for AI Agent Backend
# Copy this file to .env and fill in your actual values
# On Windows: copy .env.example .env
# On Linux/Mac: cp .env.example .env
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Server=127.0.0.1;Port=3306;Database=AiAgentDb;User=root;Password=

# JWT (change this in production!)
Jwt__Key=super-secure-32-char-key-1234567890123456

# Google OAuth
# Get credentials at https://console.cloud.google.com/apis/credentials
Google__ClientId=
Google__ClientSecret=

# Telegram
# Get bot token from @BotFather on Telegram
Messaging__Telegram__Enabled=false
Messaging__Telegram__BotToken=

# WhatsApp Cloud API
# Get credentials from https://developers.facebook.com
Messaging__WhatsApp__Enabled=false
Messaging__WhatsApp__AccessToken=
Messaging__WhatsApp__VerifyToken=ai-agent-verify-2024
Messaging__WhatsApp__PhoneNumberId=

# SMTP / Email (Gmail example)
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
Smtp__Username=
Smtp__Password=

# Trello
# Get credentials at https://trello.com/power-ups/admin
Trello__ApiKey=
Trello__AccessToken=

# Gemini AI
# Get API key at https://aistudio.google.com/apikey
Gemini__ApiKey=

# OpenAI (fallback AI provider)
# Get API key at https://platform.openai.com/api-keys
OpenAI__ApiKey=
OpenAI__Model=gpt-4o-mini

# AI Agent
AiAgent__BaseUrl=http://localhost:5000
